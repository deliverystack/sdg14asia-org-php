{
  "version": 2,
  "builds": [
    {
      "src": "api/router.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "public_html/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|images|assets)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "api/router.php"
    }
  ]
}