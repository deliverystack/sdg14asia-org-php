{
  "version": 2,
  "builds": [
    {
      "src": "public_html/**/*.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "public_html/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/$",
      "dest": "/public_html/index.php"
    },
    {
      "src": "/([^/]+)$",
      "dest": "/public_html/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public_html/$1"
    }
  ]
}