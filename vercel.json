{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "includes/**"
    }
  },
  "routes": [
    {
      "src": "/(css|js|images|assets|forms|files|favicon.ico|styles.css|main.js)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}