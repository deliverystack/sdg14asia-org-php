{
  "version": 2,
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.3" },
    "router.php": { "runtime": "vercel-php@0.7.3" }
  },
  "routes": [
    {
      "src": "/(css|js|png|pdf|ico)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public_html/sitemap.xml"
    },
    {
      "src": "/sitemap.html",
      "dest": "/public_html/sitemap.html"
    },
    {
      "src": "/(.*)",
      "dest": "/router.php"
    }
  ]
}