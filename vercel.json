{
  "version": 2,
  "functions": {
    "public_html/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/public_html/index.php"
    },
    {
      "src": "/(favicon.ico|styles.css|main.js|sitemap.xml|sitemap.html)",
      "dest": "/public_html/$1"
    },
    {
      "src": "/(images|files|forms)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/([^/]+)$",
      "dest": "/public_html/$1.php"
    }
  ]
}