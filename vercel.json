{
  "version": 2,
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.7.3" }
  },
  "routes": [
    {
      "src": "/(css|js|png|jpg|jpeg|svg|pdf|ico)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/index.php"
    },
    {
      "src": "/sitemap.html",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}