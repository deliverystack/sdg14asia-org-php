{
  "version": 2,
  "routes": [
    {
      "src": "/(css|js|images|files|forms|favicon.ico|styles.css|main.js)",
      "dest": "/public_html/$1"
    },
    {
      "src": "/(css|js|images|files|forms)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}