{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.9.0"
    }
  ],
  "routes": [
    {
      "src": "/(favicon.ico|styles.css|main.js)",
      "dest": "/public_html/$1"
    },
    {
      "src": "/(images|files|forms)/(.*)",
      "dest": "/public_html/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}